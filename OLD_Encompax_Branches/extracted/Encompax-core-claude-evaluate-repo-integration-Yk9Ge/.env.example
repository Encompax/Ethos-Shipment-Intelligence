# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=4000
DATABASE_URL=file:./prisma/dev.db

# ─── SIL (Shipment Intelligence Layer) ────────────────────────────────────────
SIL_PORT=3001
SIL_HOST=0.0.0.0
SIL_DB_PATH=./db/sil.db

# ─── StarShip Poller ──────────────────────────────────────────────────────────
STARSHIP_BASE_URL=http://your-starship-host:180
STARSHIP_USER=
STARSHIP_PASS=
STARSHIP_POLL_INTERVAL_MS=60000

# ─── FedEx Enricher ───────────────────────────────────────────────────────────
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_ENRICHER_INTERVAL_MS=900000

# ─── Karrio (disabled by default) ─────────────────────────────────────────────
ENABLE_KARRIO=0
KARRIO_API_KEY=
KARRIO_BASE_URL=http://karrio:8000/api
KARRIO_POLL_INTERVAL_MS=300000

# ─── Paycom Integration ───────────────────────────────────────────────────────
PAYCOM_API_KEY=
PAYCOM_COMPANY_ID=

# ─── Dynamics GP Integration ──────────────────────────────────────────────────
DYNAMICS_GP_API_KEY=
DYNAMICS_GP_TENANT_ID=

# ─── Velocity Integration ─────────────────────────────────────────────────────
VELOCITY_API_KEY=
VELOCITY_FACILITY_ID=

# ─── Ninety.io Integration ────────────────────────────────────────────────────
NINETY_IO_API_KEY=
