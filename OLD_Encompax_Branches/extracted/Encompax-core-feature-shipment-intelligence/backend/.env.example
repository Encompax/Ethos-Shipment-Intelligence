# Capability adapter credentials
# Keep vendor-specific secrets here, but treat them as implementation details
# behind generic business capabilities such as HRIS, ERP, and Operations System.

# HRIS capability (current adapter: Paycom)
PAYCOM_API_KEY=
PAYCOM_COMPANY_ID=
PAYCOM_SYNC_INTERVAL_MS=3600000

# ERP capability (current adapter: Dynamics GP / Business Central)
DYNAMICS_GP_API_KEY=
DYNAMICS_GP_TENANT_ID=
DYNAMICS_GP_SYNC_INTERVAL_MS=1800000

# Quality / Operations capability (current adapter: Velocity)
VELOCITY_API_KEY=
VELOCITY_FACILITY_ID=
VELOCITY_SYNC_INTERVAL_MS=300000

# Operations System capability (current adapter: Ninety.io)
NINETY_IO_API_KEY=
NINETY_IO_SYNC_INTERVAL_MS=3600000

# Shared metrics database
METRICS_DB_PATH=
